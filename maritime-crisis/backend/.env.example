# Maritime Crisis Backend - Environment Variables
# Copy this file to .env and fill in your actual values

# ─── Database (PostgreSQL via Supabase or local) ────────────────────────────────
# Format: postgresql://username:password@host:port/database
# Supabase example: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/maritime"

# ─── Server Configuration ──────────────────────────────────────────────────────
PORT="3001"
WS_PORT="3001"
NODE_ENV="development"

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="maritime-crisis-dev-secret-change-in-prod-min-32-chars"

# ─── AI Service (Groq) ─────────────────────────────────────────────────────────
# Get free key from: https://console.groq.com/keys
# Leave empty to use fallback responses
GROQ_API_KEY=""

# ─── Simulation & Performance ──────────────────────────────────────────────────
# Simulation tick interval in milliseconds (1000 = 1 Hz)
TICK_INTERVAL_MS="1000"

# Weather cache time-to-live in milliseconds (300000 = 5 minutes)
WEATHER_CACHE_TTL_MS="300000"

# Snapshot capture interval in milliseconds (30000 = 30 seconds)
SNAPSHOT_INTERVAL_MS="30000"

# Snapshots to retain in memory (120 = 1 hour at 30s intervals)
SNAPSHOT_RETENTION_COUNT="120"

# ─── Geospatial Thresholds ────────────────────────────────────────────────────
# Proximity warning threshold in kilometers
PROXIMITY_THRESHOLD_KM="2.0"

# Weather fuel penalty multiplier (0.30 = 30% extra consumption)
ADVERSE_WEATHER_FUEL_PENALTY="0.30"

# ─── Grid Resolution for A* Routing ───────────────────────────────────────────
# Degrees per grid cell (0.15 = ~16km, 0.08 = ~9km, 0.05 = ~5.5km)
# Finer = more accurate paths but slower computation
GRID_RES_DEG="0.15"
