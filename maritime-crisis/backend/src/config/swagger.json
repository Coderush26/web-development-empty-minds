                      "items": {
                        "$ref": "#/components/schemas/Alert"
                      }
                    },
                    "activeZones": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/RestrictedZone"
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
